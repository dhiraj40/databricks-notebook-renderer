{
  "name": "databricks-notebook-renderer",
  "displayName": "Databricks Notebook Renderer",
  "description": "VS Code serializer and custom output renderer for Databricks-style source notebooks.",
  "version": "1.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/dhiraj40/databricks-notebook-renderer.git"
  },
  "publisher": "dhiraj-k",
  "icon": "logo.png",
  "license": "MIT",
  "engines": {
    "vscode": "^1.101.0"
  },
  "keywords": [
    "notebookRenderer",
    "databricks",
    "notebook",
    "vscode"
  ],
  "categories": [
    "Other"
  ],
  "activationEvents": ["onNotebook:databricks-notebook-renderer"],
  "main": "./out/extension/extension.js",
  "browser": "./out/extension/extension.web.js",
  "contributes": {
    "commands": [
      {
        "command": "databricksNotebookRenderer.refreshClusters",
        "title": "Databricks Notebook: Refresh Clusters"
      },
      {
        "command": "databricksNotebookRenderer.previewPythonSource",
        "title": "Databricks Notebook: Preview Python Source"
      }
    ],
    "configuration": {
      "title": "Databricks Notebook Renderer",
      "properties": {
        "databricksNotebookRenderer.databricksCliPath": {
          "type": "string",
          "default": "databricks",
          "description": "Path to the Databricks CLI executable used to discover clusters."
        },
        "databricksNotebookRenderer.databricksProfile": {
          "type": "string",
          "default": "",
          "description": "Optional Databricks CLI profile to use when discovering clusters."
        },
        "databricksNotebookRenderer.databricksCommandTimeoutSeconds": {
          "type": "number",
          "default": 120,
          "minimum": 10,
          "description": "Maximum time to wait for a Databricks remote cell execution to finish."
        }
      }
    },
    "notebookRenderer": [
      {
        "id": "databricks-notebook-renderer",
        "entrypoint": "./out/client/index.js",
        "displayName": "Databricks Notebook Renderer",
        "mimeTypes": [
          "x-application/custom-json-output"
        ]
      }
    ],
    "notebooks": [
      
      {
        "type": "databricks-notebook-renderer",
        "displayName": "Databricks Source Notebook",
        "selector": [
          {
            "filenamePattern": "*.py"
          }
        ]
      }
    ],
    "menus": {
      "notebook/toolbar": [
        {
          "command": "databricksNotebookRenderer.previewPythonSource",
          "when": "notebookType == databricks-notebook-renderer",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "webpack --mode production",
    "lint": "eslint src",
    "watch": "webpack --mode development --watch",
    "pretest": "webpack --mode development && tsc -p src/test/tsconfig.json && npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.39",
    "@types/vscode": "^1.101.0",
    "@types/vscode-notebook-renderer": "^1.72.3",
    "@types/webpack-env": "^1.18.8",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.5.2",
    "css-loader": "^7.1.2",
    "eslint": "^9.25.1",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "glob": "^11.0.2",
    "mocha": "^11.1.0",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.2",
    "typescript": "^5.8.3",
    "util": "^0.12.5",
    "vscode-notebook-error-overlay": "^1.1.0",
    "webpack": "^5.99.7",
    "webpack-cli": "^6.0.1"
  }
}
